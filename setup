#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HOST="claude"
FORWARD_ARGS=()

usage() {
  cat <<'EOF'
사용법:
  ./setup --host claude [--with-browser] [--dry-run]
  ./setup --host codex [--with-browser] [--force] [--dry-run]
  ./setup --host auto [--with-browser] [--force] [--dry-run]

설명:
  공개용 setup 엔트리포인트입니다.
  내부적으로는 install.sh를 호출합니다.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      [[ $# -ge 2 ]] || { echo "Missing value for --host" >&2; exit 1; }
      HOST="$2"
      shift 2
      ;;
    --host=*)
      HOST="${1#--host=}"
      shift
      ;;
    --with-browser|--force|--dry-run)
      FORWARD_ARGS+=("$1")
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

case "$HOST" in
  auto)
    if command -v claude >/dev/null 2>&1; then
      HOST="claude"
    elif command -v codex >/dev/null 2>&1; then
      HOST="codex"
    else
      HOST="claude"
    fi
    ;;
  claude|codex)
    ;;
  *)
    echo "Unknown --host value: $HOST (expected claude, codex, or auto)" >&2
    exit 1
    ;;
esac

if [[ ${#FORWARD_ARGS[@]} -gt 0 ]]; then
  exec "$ROOT_DIR/install.sh" "$HOST" "${FORWARD_ARGS[@]}"
else
  exec "$ROOT_DIR/install.sh" "$HOST"
fi
